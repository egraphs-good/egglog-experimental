(primitive add (i64 i64) i64 (+ _0 _1))
(check (= (add 2 3) 5))

(primitive five () i64 5)
(check (= (five) 5))

(primitive add1-div (i64 i64) i64 (+ (/ _0 _1) 1))
(check (= (add1-div 4 2) 3))
(fail (check (= (add1-div 4 0) 0)))

(function f (i64) i64 :no-merge)
(set (f 4) 9)
(primitive via-f (i64) i64 (+ (f _0) 1))
(check (= (via-f 4) 10))
(fail (check (= (via-f 5) 0)))

(sort Math)
(constructor Num (i64) Math)
(function math-score (Math) i64 :no-merge)
(set (math-score (Num 4)) 9)
(primitive math-plus1 (Math) i64 (+ (math-score _0) 1))
(check (= (math-plus1 (Num 4)) 10))
(fail (check (= (math-plus1 (Num 5)) 0)))
(primitive make-num (i64) Math (Num _0))
(let $make-num-6 (make-num 6))
(check (= $make-num-6 (Num 6)))
(primitive five-num () Math (Num 5))
(let $five-num (five-num))
(check (= $five-num (Num 5)))

(sort IntMap (Map i64 i64))
(primitive singleton-map (i64) IntMap (map-insert (map-empty) _0 (+ _0 1)))
(check (= (singleton-map 2) (map-insert (map-empty) 2 3)))

(sort MaybeInt (Maybe i64))
(sort IntThunk (UnstableFn () i64))
(primitive maybe-unwrap-caught (MaybeInt) MaybeInt (unstable-catch (unstable-fn "maybe-unwrap" _0)))
(check (= (maybe-unwrap-caught (maybe-some 9)) (maybe-some 9)))
(check (= (maybe-unwrap-caught (maybe-none)) (maybe-none)))

(sort AddFn (UnstableFn (i64 i64) i64))
(check (= (unstable-app (unstable-fn "add") 2 3) 5))
(sort MakeNumFn (UnstableFn (i64) Math))
(let $make-num-7 (unstable-app (unstable-fn "make-num") 7))
(check (= $make-num-7 (Num 7)))
